{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "packageRules": [
    {
      "description": "Auto-merge lockfile-only updates",
      "matchUpdateTypes": ["lockFileMaintenance", "pin"],
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "rebase"
    },
    {
      "description": "Auto-merge patch and minor dependency updates after CI passes",
      "matchUpdateTypes": ["patch", "minor"],
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "rebase"
    }
  ],
  "rebaseWhen": "behind-base-branch"
}
