{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 100,
  "tabWidth": 2,
  "semi": true,
  "singleQuote": false,
  "trailingComma": "es5",
  "arrowParens": "always",
  "endOfLine": "lf",
  "sortImports": true,
  "svelte": {
    "printWidth": 100,
    "singleQuote": false,
    "semi": true,
    "trailingComma": "es5",
    "indentScriptAndStyle": false
  },
  "ignorePatterns": [
    "**/node_modules/**",
    "**/dist/**",
    "**/.svelte-kit/**",
    "**/.cache/**",
    "**/.bun/**",
    "playwright-report/**",
    "test-results/**",
    "coverage/**",
    ".claude/worktrees/**",
    "pnpm-lock.yaml",
    "**/*.scss",
    "docs/**/*.md",
    "**/*.html"
  ]
}
