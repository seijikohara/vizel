# dependencies (bun install)
node_modules

# output
out
dist
*.tgz
.svelte-kit

# code coverage
coverage
*.lcov

# logs
logs
_.log
report.[0-9]_.[0-9]_.[0-9]_.[0-9]_.json

# dotenv environment variable files
.env
.env.development.local
.env.test.local
.env.production.local
.env.local

# caches
.eslintcache
.cache
*.tsbuildinfo

# TypeScript declaration build artifacts in source directories
packages/*/src/**/*.d.ts
packages/*/src/**/*.d.ts.map
!packages/*/src/env.d.ts

# VitePress
docs/.vitepress/dist
docs/.vitepress/cache

# TypeDoc-generated API reference (run `pnpm docs:api` to regenerate)
docs/api/generated

# IntelliJ based IDEs
.idea

# Finder (MacOS) folder config
.DS_Store
# Playwright MCP server scratch output (unrelated to the test runner)
.playwright-mcp/

# Claude Code (local-only)
.claude/settings.local.json
.claude/worktrees/
CLAUDE.local.md

# Claude Code transient lock file
.claude/scheduled_tasks.lock

# Vitest browser failure screenshots and attachments (generated).
# The visual suite's committed baselines under tests/visual/specs/__screenshots__
# are intentionally tracked and excluded from these patterns.
tests/ct/*/specs/__screenshots__/
tests/a11y/*/specs/__screenshots__/
tests/**/.vitest-attachments/

# Playwright build artifacts
playwright-report/
test-results/
