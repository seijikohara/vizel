{
  "name": "vizel",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev:react": "pnpm --filter @vizel/demo-react dev",
    "dev:vue": "pnpm --filter @vizel/demo-vue dev",
    "dev:svelte": "pnpm --filter @vizel/demo-svelte dev",
    "dev:all": "concurrently -n react,vue,svelte -c blue,green,magenta \"pnpm dev:react\" \"pnpm dev:vue\" \"pnpm dev:svelte\"",
    "build": "pnpm -r --if-present run build && node scripts/add-dts-extensions.mjs packages/core/dist packages/headless/dist packages/react/dist packages/vue/dist packages/svelte/dist",
    "docs:api": "typedoc && node scripts/postprocess-typedoc.ts",
    "docs:dev": "vitepress dev docs",
    "docs:build": "pnpm build && pnpm docs:api && vitepress build docs && pnpm docs:build:demos",
    "docs:build:demos": "pnpm docs:build:demo:react && pnpm docs:build:demo:vue && pnpm docs:build:demo:svelte && pnpm docs:copy:demos",
    "docs:build:demo:react": "cd apps/demo/react && pnpm exec vite build --base=/vizel/demo/react/",
    "docs:build:demo:vue": "cd apps/demo/vue && pnpm exec vite build --base=/vizel/demo/vue/",
    "docs:build:demo:svelte": "cd apps/demo/svelte && pnpm exec vite build --base=/vizel/demo/svelte/",
    "docs:copy:demos": "mkdir -p docs/.vitepress/dist/demo && cp -r apps/demo/react/dist docs/.vitepress/dist/demo/react && cp -r apps/demo/vue/dist docs/.vitepress/dist/demo/vue && cp -r apps/demo/svelte/dist docs/.vitepress/dist/demo/svelte",
    "docs:preview": "vitepress preview docs",
    "test": "pnpm -r --if-present run test",
    "test:ct": "pnpm test:ct:react && pnpm test:ct:vue && pnpm test:ct:svelte",
    "test:ct:react": "vitest run --config vitest.browser.config.ts --project='react-*'",
    "test:ct:vue": "vitest run --config vitest.browser.config.ts --project='vue-*'",
    "test:ct:svelte": "vitest run --config vitest.browser.config.ts --project='svelte-*'",
    "test:md-roundtrip": "vitest run --config vitest.browser.config.ts --project=roundtrip",
    "test:a11y": "vitest run --config vitest.browser.config.ts --project=a11y-react --project=a11y-vue --project=a11y-svelte",
    "test:a11y:react": "vitest run --config vitest.browser.config.ts --project=a11y-react",
    "test:a11y:vue": "vitest run --config vitest.browser.config.ts --project=a11y-vue",
    "test:a11y:svelte": "vitest run --config vitest.browser.config.ts --project=a11y-svelte",
    "test:visual": "vitest run --config vitest.browser.config.ts --project=visual",
    "test:visual:update": "vitest run --config vitest.browser.config.ts --project=visual --update",
    "typecheck": "pnpm -r --if-present run typecheck",
    "lint": "biome lint --error-on-warnings .",
    "lint:fix": "biome lint --write .",
    "format": "biome format .",
    "format:fix": "biome format --write .",
    "check": "biome check --error-on-warnings .",
    "check:fix": "biome check --write .",
    "check:feature-parity": "node scripts/check-feature-parity.ts",
    "check:aria-contract": "node scripts/check-aria-contract.ts",
    "check:scenarios": "node tests/ct/parity/check-scenarios.ts",
    "check:adr-compliance": "node scripts/check-adr-compliance.ts",
    "check:ct-parity": "node scripts/check-ct-parity.ts",
    "check:ssr": "node scripts/check-ssr-safety.ts",
    "check:nolet": "node scripts/check-no-let.ts",
    "check:attw": "for pkg in core headless react vue svelte; do attw --pack packages/$pkg --config-path .attw.json || exit 1; done",
    "prepare": "lefthook install",
    "deps:check": "pnpm dlx taze major -r",
    "deps:update": "pnpm dlx taze major -r -w && pnpm install",
    "check:publishable": "node scripts/check-publishable.ts"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.4",
    "@biomejs/biome": "^2.5.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tiptap/core": "^3.26.1",
    "@tiptap/extension-blockquote": "^3.26.1",
    "@tiptap/extension-bold": "^3.26.1",
    "@tiptap/extension-bubble-menu": "^3.26.1",
    "@tiptap/extension-bullet-list": "^3.26.1",
    "@tiptap/extension-character-count": "^3.26.1",
    "@tiptap/extension-code": "^3.26.1",
    "@tiptap/extension-code-block": "^3.26.1",
    "@tiptap/extension-code-block-lowlight": "^3.26.1",
    "@tiptap/extension-collaboration": "^3.26.1",
    "@tiptap/extension-color": "^3.26.1",
    "@tiptap/extension-details": "^3.26.1",
    "@tiptap/extension-document": "^3.26.1",
    "@tiptap/extension-drag-handle": "^3.26.1",
    "@tiptap/extension-dropcursor": "^3.26.1",
    "@tiptap/extension-file-handler": "^3.26.1",
    "@tiptap/extension-gapcursor": "^3.26.1",
    "@tiptap/extension-hard-break": "^3.26.1",
    "@tiptap/extension-heading": "^3.26.1",
    "@tiptap/extension-highlight": "^3.26.1",
    "@tiptap/extension-history": "^3.26.1",
    "@tiptap/extension-horizontal-rule": "^3.26.1",
    "@tiptap/extension-image": "^3.26.1",
    "@tiptap/extension-italic": "^3.26.1",
    "@tiptap/extension-link": "^3.26.1",
    "@tiptap/extension-list-item": "^3.26.1",
    "@tiptap/extension-list-keymap": "^3.26.1",
    "@tiptap/extension-ordered-list": "^3.26.1",
    "@tiptap/extension-paragraph": "^3.26.1",
    "@tiptap/extension-placeholder": "^3.26.1",
    "@tiptap/extension-strike": "^3.26.1",
    "@tiptap/extension-table": "^3.26.1",
    "@tiptap/extension-task-item": "^3.26.1",
    "@tiptap/extension-task-list": "^3.26.1",
    "@tiptap/extension-text": "^3.26.1",
    "@tiptap/extension-text-style": "^3.26.1",
    "@tiptap/extension-underline": "^3.26.1",
    "@tiptap/pm": "^3.26.1",
    "@tiptap/suggestion": "^3.26.1",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/browser-playwright": "^4.1.9",
    "@vue/compiler-dom": "^3.5.38",
    "axe-core": "^4.11.0",
    "concurrently": "^10.0.3",
    "lefthook": "^2.1.9",
    "linkedom": "^0.18.12",
    "mermaid": "^11.15.0",
    "oxc-minify": "^0.138.0",
    "playwright": "1.61.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "svelte": "^5.56.3",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.12.0",
    "typedoc-vitepress-theme": "^1.1.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitepress": "^2.0.0-alpha.17",
    "vitepress-plugin-mermaid": "^2.0.17",
    "vitest": "^4.1.9",
    "vitest-browser-react": "^2.2.0",
    "vitest-browser-svelte": "2.2.0",
    "vitest-browser-vue": "2.1.0",
    "vue": "^3.5.38"
  }
}
