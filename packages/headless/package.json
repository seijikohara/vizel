{
  "name": "@vizel/headless",
  "version": "2.0.0",
  "type": "module",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/seijikohara/vizel",
    "directory": "packages/headless"
  },
  "description": "Framework-neutral UI primitives consumed by every Vizel framework adapter",
  "license": "MIT",
  "author": "Seiji Kohara",
  "homepage": "https://seijikohara.github.io/vizel/",
  "bugs": {
    "url": "https://github.com/seijikohara/vizel/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "vizel",
    "headless",
    "ui",
    "primitives",
    "combobox",
    "popover",
    "dismissable",
    "focus-trap",
    "floating",
    "keyboard"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./dismissable": {
      "types": "./dist/dismissable/index.d.ts",
      "import": "./dist/dismissable/index.js",
      "default": "./dist/dismissable/index.js"
    },
    "./floating": {
      "types": "./dist/floating/index.d.ts",
      "import": "./dist/floating/index.js",
      "default": "./dist/floating/index.js"
    },
    "./keyboard": {
      "types": "./dist/keyboard/index.d.ts",
      "import": "./dist/keyboard/index.js",
      "default": "./dist/keyboard/index.js"
    },
    "./popover": {
      "types": "./dist/popover/index.d.ts",
      "import": "./dist/popover/index.js",
      "default": "./dist/popover/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "node --no-warnings --experimental-test-module-mocks --test \"__tests__/**/*.test.ts\""
  },
  "dependencies": {
    "@floating-ui/dom": "^1.7.6"
  },
  "devDependencies": {
    "vite": "^8.0.14",
    "vite-plugin-dts": "^5.0.1"
  }
}
