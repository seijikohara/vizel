{
  "name": "@vizel/vue",
  "version": "2.0.2",
  "description": "Vue 3 components and composables for Vizel block-based Markdown editor",
  "keywords": [
    "block-editor",
    "editor",
    "markdown",
    "rich-text",
    "tiptap",
    "vizel",
    "vue",
    "wysiwyg"
  ],
  "homepage": "https://seijikohara.github.io/vizel/",
  "bugs": {
    "url": "https://github.com/seijikohara/vizel/issues"
  },
  "license": "MIT",
  "author": "Seiji Kohara",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/seijikohara/vizel.git",
    "directory": "packages/vue"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": [
    "./dist/index.js"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css",
    "./styles/variables.css": "./dist/styles/variables.css",
    "./styles/components.css": "./dist/styles/components.css",
    "./mathematics.css": "./dist/mathematics.css"
  },
  "scripts": {
    "build": "vite build && node scripts/write-style-shims.mjs",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@iconify/vue": "^5.0.1",
    "@vizel/core": "workspace:^",
    "@vizel/headless": "workspace:^"
  },
  "devDependencies": {
    "@tiptap/extension-bold": "^3.26.1",
    "@tiptap/extension-code": "^3.26.1",
    "@tiptap/extension-color": "^3.26.1",
    "@tiptap/extension-highlight": "^3.26.1",
    "@tiptap/extension-italic": "^3.26.1",
    "@tiptap/extension-strike": "^3.26.1",
    "@tiptap/extension-subscript": "^3.26.1",
    "@tiptap/extension-superscript": "^3.26.1",
    "@tiptap/extension-text-style": "^3.26.1",
    "@tiptap/extension-underline": "^3.26.1",
    "@tiptap/pm": "^3.26.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vizel/core": "workspace:^",
    "vite": "^8.0.16",
    "vite-plugin-dts": "^5.0.2",
    "vue-tsc": "^3.3.7"
  },
  "peerDependencies": {
    "@tiptap/extension-bold": "^3.23.4",
    "@tiptap/extension-code": "^3.23.4",
    "@tiptap/extension-color": "^3.23.4",
    "@tiptap/extension-highlight": "^3.23.4",
    "@tiptap/extension-italic": "^3.23.4",
    "@tiptap/extension-strike": "^3.23.4",
    "@tiptap/extension-subscript": "^3.23.4",
    "@tiptap/extension-superscript": "^3.23.4",
    "@tiptap/extension-text-style": "^3.23.4",
    "@tiptap/extension-underline": "^3.23.4",
    "@tiptap/pm": "^3.23.4",
    "vue": "^3.4"
  },
  "engines": {
    "node": ">=24"
  }
}
