{
  "name": "@vizel/core",
  "version": "2.0.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/seijikohara/vizel.git",
    "directory": "packages/core"
  },
  "description": "Framework-agnostic core for Vizel block-based Markdown editor built on Tiptap",
  "license": "MIT",
  "author": "Seiji Kohara",
  "homepage": "https://seijikohara.github.io/vizel/",
  "bugs": {
    "url": "https://github.com/seijikohara/vizel/issues"
  },
  "engines": {
    "node": ">=24"
  },
  "keywords": [
    "vizel",
    "tiptap",
    "editor",
    "markdown",
    "wysiwyg",
    "rich-text",
    "block-editor",
    "prosemirror"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": [
    "*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css",
    "./styles/variables.css": "./dist/styles/variables.css",
    "./styles/components.css": "./dist/styles/components.css",
    "./mathematics.css": "./dist/mathematics.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && npm run build:css",
    "build:css": "npm run build:css:styles && npm run build:css:variables && npm run build:css:components && npm run build:css:mathematics",
    "build:css:styles": "sass --load-path=src/styles --load-path=node_modules src/styles/index.scss dist/styles.css --style=compressed",
    "build:css:variables": "sass --load-path=src/styles --load-path=node_modules src/styles/entries/variables.scss dist/styles/variables.css --style=compressed",
    "build:css:components": "sass --load-path=src/styles --load-path=node_modules src/styles/entries/components.scss dist/styles/components.css --style=compressed",
    "build:css:mathematics": "node scripts/build-mathematics-css.mjs",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@hpcc-js/wasm-graphviz": "^1.0.0",
    "@tiptap/core": "^3.23.4",
    "@tiptap/extension-blockquote": "^3.23.4",
    "@tiptap/extension-bold": "^3.23.4",
    "@tiptap/extension-bubble-menu": "^3.23.4",
    "@tiptap/extension-bullet-list": "^3.23.4",
    "@tiptap/extension-character-count": "^3.23.4",
    "@tiptap/extension-code": "^3.23.4",
    "@tiptap/extension-code-block": "^3.23.4",
    "@tiptap/extension-code-block-lowlight": "^3.23.4",
    "@tiptap/extension-collaboration": "^3.23.4",
    "@tiptap/extension-collaboration-cursor": "^3.0.0",
    "@tiptap/extension-color": "^3.23.4",
    "@tiptap/extension-details": "^3.23.4",
    "@tiptap/extension-document": "^3.23.4",
    "@tiptap/extension-drag-handle": "^3.23.4",
    "@tiptap/extension-dropcursor": "^3.23.4",
    "@tiptap/extension-file-handler": "^3.23.4",
    "@tiptap/extension-gapcursor": "^3.23.4",
    "@tiptap/extension-hard-break": "^3.23.4",
    "@tiptap/extension-heading": "^3.23.4",
    "@tiptap/extension-highlight": "^3.23.4",
    "@tiptap/extension-history": "^3.23.4",
    "@tiptap/extension-horizontal-rule": "^3.23.4",
    "@tiptap/extension-image": "^3.23.4",
    "@tiptap/extension-italic": "^3.23.4",
    "@tiptap/extension-link": "^3.23.4",
    "@tiptap/extension-list-item": "^3.23.4",
    "@tiptap/extension-list-keymap": "^3.23.4",
    "@tiptap/extension-mention": "^3.23.4",
    "@tiptap/extension-ordered-list": "^3.23.4",
    "@tiptap/extension-paragraph": "^3.23.4",
    "@tiptap/extension-placeholder": "^3.23.4",
    "@tiptap/extension-strike": "^3.23.4",
    "@tiptap/extension-subscript": "^3.23.4",
    "@tiptap/extension-superscript": "^3.23.4",
    "@tiptap/extension-table": "^3.23.4",
    "@tiptap/extension-task-item": "^3.23.4",
    "@tiptap/extension-task-list": "^3.23.4",
    "@tiptap/extension-text": "^3.23.4",
    "@tiptap/extension-text-style": "^3.23.4",
    "@tiptap/extension-typography": "^3.23.4",
    "@tiptap/extension-underline": "^3.23.4",
    "@tiptap/pm": "^3.23.4",
    "@tiptap/suggestion": "^3.23.4",
    "fuse.js": "^7.1.0",
    "katex": "^0.16.0",
    "linkedom": "^0.18.0",
    "lowlight": "^3.0.0",
    "mermaid": "^11.15.0",
    "y-websocket": "^2.0.0 || ^3.0.0",
    "yjs": "^13.6.0"
  },
  "peerDependenciesMeta": {
    "@hpcc-js/wasm-graphviz": {
      "optional": true
    },
    "@tiptap/extension-collaboration": {
      "optional": true
    },
    "@tiptap/extension-collaboration-cursor": {
      "optional": true
    },
    "fuse.js": {
      "optional": true
    },
    "katex": {
      "optional": true
    },
    "linkedom": {
      "optional": true
    },
    "lowlight": {
      "optional": true
    },
    "mermaid": {
      "optional": true
    },
    "yjs": {
      "optional": true
    },
    "y-websocket": {
      "optional": true
    }
  },
  "devDependencies": {
    "@iconify-json/lucide": "^1.2.112",
    "@iconify/utils": "^3.1.3",
    "@tiptap/extension-mention": "^3.26.1",
    "@tiptap/extension-subscript": "^3.26.1",
    "@tiptap/extension-superscript": "^3.26.1",
    "@tiptap/extension-typography": "^3.26.1",
    "@types/markdown-it": "^14.1.2",
    "@types/markdown-it-footnote": "^3.0.4",
    "dompurify": "^3.4.10",
    "fuse.js": "^7.4.2",
    "sass": "^1.101.0",
    "vite": "^8.0.16",
    "vite-plugin-dts": "^5.0.2"
  },
  "dependencies": {
    "@tiptap/extension-list": "^3.26.1",
    "@tiptap/extension-node-range": "^3.26.1",
    "@tiptap/extensions": "^3.26.1",
    "@tiptap/y-tiptap": "^3.0.5",
    "@vizel/headless": "workspace:^",
    "markdown-it": "^14.2.0",
    "markdown-it-deflist": "^3.0.1",
    "markdown-it-footnote": "^4.0.0",
    "markdown-it-sub": "^2.0.0",
    "markdown-it-sup": "^2.0.0",
    "prosemirror-markdown": "^1.13.4",
    "tiptap-markdown": "^0.9.0"
  }
}
